pipeline {
  agent any  // Run on any available Jenkins agent/node

  tools {
    maven 'Maven3'  // Use Maven tool configured in Jenkins
  }

  environment {
    MAVEN_OPTS = "-Xmx1024m"  // Set Maven memory options
  }

stages {

    stage('Checkout') {
      steps {
        // Pull latest code from GitHub
        checkout scm
      }
    }
    stage('Start Docker Grid'){
    steps{
    sh 'docker-compose up -d'
      }
    }

    stage('Build, Test & Generate Reports') {
      steps {
        // Run clean, compile, test, and generate reports in ONE command
        sh 'mvn clean verify'
      }
    }

    stage('Archive Artifacts') {
      steps {
        // Save build artifacts
        archiveArtifacts artifacts: 'target/*.jar, target/**/*.html, target/**/*.json', allowEmptyArchive: true
      }
    }

    stage('Publish Cucumber Report') {
      steps {
        // Publish interactive Cucumber report

        cucumber buildStatus: 'SUCCESS',
                 fileIncludePattern: '**/*.json',
                 jsonReportDirectory: 'target'
      }
    }
  }

  post {
    always {
      script {
              sh 'docker-compose down'
        // Always publish test results
        junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
        archiveArtifacts artifacts: 'logs/**', allowEmptyArchive: true
      }
    }
    success {
      echo 'Build passed'
    }
    failure {
      echo 'Build failed'
    }
  }
}
