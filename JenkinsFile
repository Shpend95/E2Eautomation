pipeline {
  agent any  // Run on any available Jenkins agent/node

  tools {
    maven 'Maven3'  // Use Maven tool configured in Jenkins
  }

  environment {
    MAVEN_OPTS = "-Xmx1024m"  // Set Maven memory options
  }

  stages {

    stage('Checkout') {
      steps {
        // Pull latest code from GitHub repository
        checkout scm
      }
    }

    stage('Build & Test') {
      steps {
        // Clean previous builds, compile code, and run tests
        sh 'mvn -B clean test'
      }
    }

    stage('Generate Cucumber Report') {
      steps {
        // Run Maven verify to generate Cucumber JSON files
        sh 'mvn verify'
      }
    }

    stage('Archive Artifacts') {
      steps {
        // Save build artifacts (JAR files, HTML reports, JSON files)
        archiveArtifacts artifacts: 'target/*.jar, target/**/*.html, target/**/*.json', allowEmptyArchive: true
      }
    }

    stage('Publish Cucumber Report') {
      steps {
        // Publish interactive Cucumber report using Cucumber Reports plugin
        cucumber buildStatus: 'SUCCESS',
                 fileIncludePattern: '**/*.json',
                 jsonReportDirectory: 'target'
      }
    }
  }

  post {
    always {
      script {
        // Always publish test results and archive logs (even if build fails)
        junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
        archiveArtifacts artifacts: 'logs/**', allowEmptyArchive: true
      }
    }
    success {
      // Print message when build succeeds
      echo 'Build passed'
    }
    failure {
      // Print message when build fails
      echo 'Build failed'
    }
  }
}